{
    "applicationId": "js.neutralino.xerox_editor",
    "version": "1.0.0",
    "defaultMode": "window",
    "documentRoot": "/resources/",
    "url": "/",
    "enableServer": true,
    "enableNativeAPI": true,
    "tokenSecurity": "one-time",
    "logging": {
        "enabled": true,
        "writeToLogFile": true
    },
    "modes": {
        "window": {
            "title": "Xerox Editor",
            "icon": "/resources/appIcon.png",
            "width": 1200,
            "height": 800,
            "minWidth": 800,
            "minHeight": 600,
            "center": true,
            "resizable": true,
            "maximizable": true,
            "enableInspector": true,
            "borderless": false,
            "alwaysOnTop": false,
            "transparent": false,
            "exitProcessOnClose": true
        }
    },
    "nativeAllowList": [
        "app.*",
        "os.*",
        "filesystem.*",
        "window.*",
        "events.*",
        "debug.*"
    ],
    "cli": {
        "binaryName": "Xerox_Editor",
        "resourcesPath": "/resources/",
        "extensionsPath": "",
        "clientLibrary": "/resources/neutralino.js",
        "binaryVersion": "6.5.0",
        "clientVersion": "6.5.0"
    }
}